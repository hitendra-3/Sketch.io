{
  "name": "sketch.io",
  "version": "1.0.0",
  "description": "Sketch.io - Real-time Collaborative Whiteboard",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix frontend && cd backend && pip install -r requirements.txt",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "cd backend && python -m uvicorn main:app --host 127.0.0.1 --port 7860 --reload",
    "dev": "npx concurrently \"npm:dev:frontend\" \"npm:dev:backend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
