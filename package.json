{
  "name": "sketch.io",
  "version": "1.0.0",
  "description": "Sketch.io - Real-time Collaborative Whiteboard",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev": "npx concurrently \"npm:dev:frontend\" \"npm:dev:backend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
